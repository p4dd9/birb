{
	"$schema": "https://developers.reddit.com/schema/config-file.v1.json",
	"name": "birb-game",
	"media": {
		"dir": "app/dist/client"
	},
	"post": {
		"dir": "app/dist/client",
		"entrypoints": {
			"default": {
				"inline": true,
				"height": "tall",
				"entry": "index.html"
			},
			"launcher": {
				"inline": true,
				"height": "tall",
				"entry": "index.html"
			},
			"daily": {
				"inline": true,
				"height": "tall",
				"entry": "index.html"
			}
		}
	},
	"server": {
		"dir": "app/dist/server",
		"entry": "index.cjs"
	},
	"permissions": {
		"redis": true,
		"reddit": {
			"enable": true,
			"asUser": ["SUBMIT_COMMENT", "SUBMIT_POST", "SUBSCRIBE_TO_SUBREDDIT"]
		},
		"http": {
			"enable": true
		},
		"payments": true
	},
	"payments": {
		"productsFile": "./app/src/products.json",
		"endpoints": {
			"fulfillOrder": "/internal/payments/fulfill",
			"refundOrder": "/internal/payments/refund"
		}
	},
	"settings": {
		"global": {
			"api-key": {
				"type": "string",
				"label": "Redditcore API Key",
				"isSecret": true
			},
			"api-base-url": {
				"type": "string",
				"label": "Redditcore API Base URL",
				"isSecret": true
			},
			"api-version": {
				"type": "string",
				"label": "Redditcore API Version",
				"isSecret": true
			}
		}
	},
	"scheduler": {
		"tasks": {
			"daily-level": {
				"endpoint": "/internal/scheduler/daily-level",
				"cron": "0 0 * * *"
			}
		}
	},
	"triggers": {
		"onAppInstall": "/internal/triggers/app-install"
	},
	"forms": {
		"manageLivesForm": "/internal/menu/manage-lives-submit"
	},
	"menu": {
		"items": [
			{
				"label": "[ADMIN] Create Launcher Post",
				"description": "Create the in-feed Birb launcher post (menu + Play).",
				"location": "subreddit",
				"forUserType": "moderator",
				"endpoint": "/internal/menu/create-launcher"
			},
			{
				"label": "[ADMIN] Create Daily Birb Post",
				"description": "Generate today's seed and post the daily Birb level now.",
				"location": "subreddit",
				"forUserType": "moderator",
				"endpoint": "/internal/menu/create-daily"
			},
			{
				"label": "💗 [ADMIN] Manage Player Lives",
				"description": "View, add, or remove a player's lives (hammertime dev only).",
				"location": "subreddit",
				"forUserType": "moderator",
				"endpoint": "/internal/menu/manage-lives"
			}
		]
	},
	"marketingAssets": {
		"icon": "logo_1024x1024.png"
	},
	"dev": {
		"subreddit": "hammertime_dev"
	}
}

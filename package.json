{
	"name": "birb",
	"version": "1.0.0",
	"private": true,
	"workspaces": [
		"app/src/client",
		"app/src/server",
		"app/src/shared"
	],
	"scripts": {
		"dev": "concurrently -k -p \"[{name}]\" -n \"CLIENT-BUILD,SERVER,DEVVIT\" -c \"cyan,green,magenta\" \"npm run dev:client-build\" \"npm run dev:server\" \"npm run dev:devvit\"",
		"dev:client": "npm run dev --workspace=@birb/client",
		"dev:client-build": "npm run dev:build --workspace=@birb/client",
		"dev:server": "npm run dev --workspace=@birb/server",
		"dev:devvit": "devvit playtest",
		"build": "npm run typecheck && npm run build:client && npm run build:server",
		"build:client": "npm run build --workspace=@birb/client",
		"build:server": "npm run build --workspace=@birb/server",
		"typecheck": "npm run typecheck:shared && npm run typecheck:server && npm run typecheck:client",
		"typecheck:shared": "tsc --noEmit -p app/src/shared",
		"typecheck:server": "tsc --noEmit -p app/src/server",
		"typecheck:client": "tsc --noEmit -p app/src/client",
		"upload": "devvit upload",
		"upload:patch": "npx devvit upload --bump patch",
		"upload:minor": "npx devvit upload --bump minor",
		"publish": "devvit publish",
		"logs": "devvit logs r/BirbGame"
	},
	"dependencies": {
		"@devvit/web": "0.13.5",
		"devvit": "0.13.5"
	},
	"devDependencies": {
		"@types/node": "^25.3.3",
		"concurrently": "^9.2.1",
		"prettier": "^3.8.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
